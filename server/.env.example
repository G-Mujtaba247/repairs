# Server Configuration
PORT=5000

# Database
MONGODB_URL_LOCAL=mongodb://localhost:27017/repairs
MONGODB_URL_PROD=mongodb+srv://username:password@cluster.mongodb.net/repairs

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Cloudinary Configuration (Image Upload)
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_URL=cloudinary://key:secret@cloudinary-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Environment
NODE_ENV=development

# CORS Settings
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# JWT (Optional for future authentication)
JWT_SECRET=your-secret-key-here
JWT_EXPIRE=7d
